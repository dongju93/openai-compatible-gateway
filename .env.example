# Copy this file to .env and fill in your values.
# All fields are optional — defaults are shown below.

# ── Upstream chat API ─────────────────────────────────────────────────────────
# Base URL of the upstream chat API (no trailing slash)
UPSTREAM_BASE_URL=http://localhost:8000

# API key / bearer token sent to upstream (leave blank if no auth required)
UPSTREAM_API_KEY=

# Path to the chat endpoint
UPSTREAM_CHAT_ENDPOINT=/chat

# Request timeout in seconds (increase for slow models)
UPSTREAM_TIMEOUT=120.0

# ── Gateway ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
